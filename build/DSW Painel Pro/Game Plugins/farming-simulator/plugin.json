  "installer": {
    "method": "tutorial_only",
    "title": "Telemetria Farming Simulator",
    "description": "O DSW le os dados do mod Farming Simulator Telemetry por pipe nomeado local.",
    "success_message": "Farming Simulator nao precisa de instalacao dentro do DSW."
  },
  "telemetry": {
    "protocol": "NamedPipe",
    "pipe_name": "fssimx"
  },
  "setup_tutorial": {
    "title": "Configuracao da telemetria do Farming Simulator",
    "summary": "Instale o mod Farming Simulator Telemetry na pasta de mods do jogo. Depois disso o DSW passa a ouvir o pipe local criado pelo mod.",
    "steps": [
      "Baixe o projeto/mod em https://github.com/Marciel032/FarmingSimulatorTelemetry",
      "Coloque a pasta ou o ZIP do mod TelemetriaFarmingSimulator na pasta de mods do Farming Simulator.",
      "Abra o Farming Simulator com o mod ativo.",
      "No DSW, selecione Farming Simulator e inicie a coleta.",
      "Se o jogo ja estiver aberto, o DSW pode ficar em aguardando telemetria ate o mod escrever no pipe fssimx."
    ],
    "notes": [
      "Este plugin ignora campos textuais como nome do veiculo.",
      "Ele prioriza campos numericos e booleanos, com destaque para dados de implementos.",
      "O mod original escreve no pipe nomeado \\\\.\\pipe\\fssimx."
    ]
  }
