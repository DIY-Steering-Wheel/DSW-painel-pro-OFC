{
  "id": "forza",
  "name": "Forza",
  "icon": "icon.png",
  "requires_install": false,
  "activity_source": "telemetry",
  "process_name": "ForzaHorizon6.exe",
  "process_names": [
    "ForzaHorizon4.exe",
    "ForzaHorizon5.exe",
    "ForzaHorizon6.exe",
    "ForzaMotorsport7.exe",
    "ForzaMotorsport.exe"
  ],
  "telemetry_script": "telemetry.py",
  "emitted_fields": [
    "engine_rpm",
    "current_gear",
    "speed",
    "park_brake",
    "electric_enabled",
    "engine_enabled",
    "fuel_percent",
    "clutch",
    "brake",
    "throttle",
    "turbo",
    "acceleration_x",
    "acceleration_y",
    "acceleration_z"
  ],
  "available_extra_fields": [
    "connected",
    "race_on",
    "packet_format",
    "engine_max_rpm",
    "engine_idle_rpm",
    "power_kw",
    "torque_nm",
    "steering",
    "yaw",
    "pitch",
    "roll",
    "velocity_x",
    "velocity_y",
    "velocity_z",
    "lap_number",
    "race_position",
    "best_lap_time",
    "last_lap_time",
    "current_lap_time",
    "race_time",
    "distance_traveled",
    "car_ordinal",
    "car_class",
    "performance_index",
    "drivetrain_type",
    "num_cylinders",
    "tire_temperature_front_left",
    "tire_temperature_front_right",
    "tire_temperature_rear_left",
    "tire_temperature_rear_right",
    "tire_slip_ratio_front_left",
    "tire_slip_ratio_front_right",
    "tire_slip_ratio_rear_left",
    "tire_slip_ratio_rear_right",
    "tire_slip_angle_front_left",
    "tire_slip_angle_front_right",
    "tire_slip_angle_rear_left",
    "tire_slip_angle_rear_right",
    "suspension_travel_front_left",
    "suspension_travel_front_right",
    "suspension_travel_rear_left",
    "suspension_travel_rear_right",
    "wheel_rotation_speed_front_left",
    "wheel_rotation_speed_front_right",
    "wheel_rotation_speed_rear_left",
    "wheel_rotation_speed_rear_right",
    "tire_wear_front_left",
    "tire_wear_front_right",
    "tire_wear_rear_left",
    "tire_wear_rear_right",
    "track_ordinal"
  ],
  "emitted_units": {
    "speed": "M/S",
    "pressure": "PSI",
    "temperature": "Fahrenheit"
  },
  "preferred_units": {
    "speed": "KM/H",
    "pressure": "BAR",
    "temperature": "Celsius"
  },
  "telemetry": {
    "protocol": "UDP",
    "bind_ip": "0.0.0.0",
    "port": 9999,
    "supported_packet_sizes": [232, 311, 324, 331]
  },
  "setup_tutorial": {
    "title": "Configuração da telemetria do Forza",
    "summary": "O plugin recebe a saída Data Out do Forza por UDP. Nenhum arquivo do jogo é alterado.",
    "steps": [
      "Abra Configurações > HUD e Jogabilidade no Forza.",
      "Ative Data Out ou UDP Race Telemetry.",
      "Use o IP 127.0.0.1 quando o jogo e o DSW estiverem no mesmo computador. Para Xbox ou outro computador, use o IP local do PC que executa o DSW.",
      "Defina a porta 9999 no jogo.",
      "No Forza Motorsport, selecione o formato Dash ou Car Dash.",
      "Entre na pista e comece a dirigir para iniciar a transmissão."
    ],
    "notes": [
      "Compatível com pacotes Sled de 232 bytes, Dash de 311 bytes, Horizon de 324 bytes e Motorsport estendido de 331 bytes.",
      "O Forza não envia telemetria durante menus, pausa, replay ou rebobinamento.",
      "No Forza Horizon 6, evite usar portas entre 5200 e 5300.",
      "Se o jogo estiver em outro dispositivo, libere a porta UDP 9999 no Firewall do Windows."
    ]
  }
}
